      "utf8": "a fireman when I grew up."
    } ]
  }, {
    "tStartMs": 17720,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "How about you, Beth?"
    } ]
  }, {
    "tStartMs": 18720,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "Did you have"
