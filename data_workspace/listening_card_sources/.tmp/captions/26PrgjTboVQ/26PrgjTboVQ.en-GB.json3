      "utf8": "any childhood dreams?"
    } ]
  }, {
    "tStartMs": 20720,
    "dDurationMs": 1830,
    "segs": [ {
      "utf8": "I wanted to be an astronaut"
    } ]
  }, {
    "tStartMs": 22550,
    "dDurationMs": 1920,
    "segs": [ {
      "utf8": "and fly to the Moon…"
    } ]
  }, {
    "tStartMs": 24470,
