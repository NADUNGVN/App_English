    "dDurationMs": 1189,
    "segs": [ {
      "utf8": "And I’m Beth."
    } ]
  }, {
    "tStartMs": 13500,
    "dDurationMs": 1990,
    "segs": [ {
      "utf8": "When I was a boy, I wanted to be"
