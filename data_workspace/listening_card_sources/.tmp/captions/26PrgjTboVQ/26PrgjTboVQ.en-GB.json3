    } ]
  }, {
    "tStartMs": 304760,
    "dDurationMs": 1120,
    "segs": [ {
      "utf8": "of your question, Neil."
    } ]
  }, {
    "tStartMs": 305880,
    "dDurationMs": 5480,
    "segs": [ {
      "utf8": "Yes, I asked about Bronnie Ware’s book,\nThe Top Five Regrets of the Dying."
    } ]
  }, {
    "tStartMs": 311360,
    "dDurationMs": 3060,
    "segs": [ {
      "utf8": "What do you think the number one regret was,\nBeth?"
    } ]
  }, {
    "tStartMs": 314420,
    "dDurationMs": 3630,
    "segs": [ {
      "utf8": "I guessed it was b) not following your dreams."
    } ]
  }, {
    "tStartMs": 318050,
    "dDurationMs": 2590,
    "segs": [ {
      "utf8": "Which was the right answer!"
    } ]
  }, {
    "tStartMs": 320640,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "Not having"
    } ]
  }, {
    "tStartMs": 321640,
    "dDurationMs": 1860,
    "segs": [ {
      "utf8": "the courage to follow your dreams was"
    } ]
  }, {
    "tStartMs": 323500,
    "dDurationMs": 3060,
    "segs": [ {
      "utf8": "listed as the top life regret."
    } ]
  }, {
    "tStartMs": 326560,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "At least we"
    } ]
  }, {
    "tStartMs": 327560,
    "dDurationMs": 1180,
    "segs": [ {
      "utf8": "have people like Daisy and Herman"
    } ]
  }, {
    "tStartMs": 328740,
    "dDurationMs": 2250,
    "segs": [ {
      "utf8": "to remind us dreams can come true!"
    } ]
  }, {
    "tStartMs": 330990,
    "dDurationMs": 2800,
    "segs": [ {
      "utf8": "OK, let’s recap the vocabulary from"
    } ]
  }, {
    "tStartMs": 333790,
    "dDurationMs": 1690,
    "segs": [ {
      "utf8": "this programme, starting with"
    } ]
  }, {
    "tStartMs": 335480,
    "dDurationMs": 2770,
    "segs": [ {
      "utf8": "'utopia' – a perfect world where"
    } ]
  }, {
    "tStartMs": 338250,
    "dDurationMs": 1410,
    "segs": [ {
      "utf8": "everyone is happy."
    } ]
  }, {
    "tStartMs": 339660,
    "dDurationMs": 1810,
    "segs": [ {
      "utf8": "If you 'struggle with an idea',"
    } ]
  }, {
    "tStartMs": 341470,
    "dDurationMs": 2100,
    "segs": [ {
      "utf8": "you find it difficult to accept."
    } ]
  }, {
    "tStartMs": 343570,
    "dDurationMs": 2270,
    "segs": [ {
      "utf8": "The adjective, outlandish, means"
    } ]
  }, {
    "tStartMs": 345840,
    "dDurationMs": 2180,
    "segs": [ {
      "utf8": "strange and unusual."
    } ]
  }, {
    "tStartMs": 348020,
    "dDurationMs": 1540,
    "segs": [ {
      "utf8": "'To conquer' something means"
    } ]
  }, {
    "tStartMs": 349560,
    "dDurationMs": 2230,
    "segs": [ {
      "utf8": "to control it by force."
    } ]
  }, {
    "tStartMs": 351790,
    "dDurationMs": 1520,
    "segs": [ {
      "utf8": "Someone who is 'humble' is"
    } ]
  }, {
    "tStartMs": 353310,
    "dDurationMs": 2090,
    "segs": [ {
      "utf8": "not proud or arrogant."
    } ]
  }, {
    "tStartMs": 355400,
    "dDurationMs": 2300,
    "segs": [ {
      "utf8": "And finally, the phrase 'a grain of sand'"
    } ]
  }, {
    "tStartMs": 357700,
    "dDurationMs": 1860,
    "segs": [ {
      "utf8": "describes something which is both"
    } ]
  }, {
    "tStartMs": 359560,
    "dDurationMs": 3130,
    "segs": [ {
      "utf8": "insignificant yet somehow important."
    } ]
  }, {
    "tStartMs": 362690,
    "dDurationMs": 2262,
    "segs": [ {
      "utf8": "Once again, our six minutes are up."
    } ]
  }, {
    "tStartMs": 364952,
    "dDurationMs": 767,
    "segs": [ {
      "utf8": "Bye for now!"
    } ]
  }, {
    "tStartMs": 365719,
    "dDurationMs": 971,
    "segs": [ {
      "utf8": "Goodbye!"
    } ]
  } ]
}
