  }, {
    "tStartMs": 26140,
    "dDurationMs": 2780,
    "segs": [ {
      "utf8": "big dreams and plans for the future."
    } ]
  }, {
    "tStartMs": 28920,
    "dDurationMs": 2240,
    "segs": [ {
      "utf8": "Unfortunately, as we grow up these"
    } ]
  }, {
    "tStartMs": 31160,
    "dDurationMs": 2710,
    "segs": [ {
      "utf8": "childhood dreams often get lost in the"
    } ]
  }, {
    "tStartMs": 33870,
    "dDurationMs": 3109,
    "segs": [ {
      "utf8": "adult world of jobs, money,"
    } ]
  }, {
    "tStartMs": 36979,
    "dDurationMs": 1540,
    "segs": [ {
      "utf8": "families and careers."
    } ]
  }, {
    "tStartMs": 38519,
    "dDurationMs": 1470,
    "segs": [ {
      "utf8": "But not for everyone…"
    } ]
  }, {
    "tStartMs": 39989,
    "dDurationMs": 2710,
    "segs": [ {
      "utf8": "Daisy, from New Zealand, and, Herman,"
    } ]
  }, {
    "tStartMs": 42699,
